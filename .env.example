# FabOps Copilot environment variables.
# Copy to `.env` (gitignored) and fill in real values. Never commit secrets.

# --- AWS ---
AWS_REGION=us-east-1

# --- LLM providers ---
# Required: Gemini is the agent's planning + diagnose + verify model.
GEMINI_API_KEY=your_gemini_key_here
# Required for evaluation only: Claude Haiku 4.5 cross-family judge.
ANTHROPIC_API_KEY=your_anthropic_key_here

# --- Macro data ingest (nightly bake only) ---
# Required by get_industry_macro_signal and the ingest scripts.
FRED_API_KEY=your_fred_key_here

# --- Observability (optional, Langfuse is auxiliary) ---
# If unset, the audit spine in DynamoDB remains the authoritative trace.
LANGFUSE_PUBLIC_KEY=pk-lf-xxx
LANGFUSE_SECRET_KEY=sk-lf-xxx
LANGFUSE_HOST=https://cloud.langfuse.com

# --- Eval harness + load testing (local/CI only, not the runtime Lambda) ---
# URL of the deployed agent API. Used by scripts/run_judge.py and
# scripts/stress_cold_start.py to hit the live endpoint.
FABOPS_API_URL=https://3ph4o9amg4.execute-api.us-east-1.amazonaws.com/getChatResponse
# If "1", run_judge.py hits the API over HTTP instead of direct Lambda invoke.
FABOPS_USE_HTTP=0

# --- Runtime feature flags (set on the Lambda, not locally) ---
# If "1", the graph runs the verify retry loop (extra Gemini call per request).
# Disabled by default for latency; flip when you want the max-quality path.
FABOPS_ENABLE_VERIFY=0
